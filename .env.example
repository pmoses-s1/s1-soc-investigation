# s1-soc-investigation settings. Copy to .env and fill in. .env is git-ignored; never commit tokens.

# ---- Required: SDL / LRQ connect ----
# Tenant CONSOLE host for the LRQ v2 API (NOT the xdr.* V1 host).
S1_CONSOLE_URL=https://your-tenant.sentinelone.net
# One or more service-user JWTs. Comma-separated = round-robin across identities,
# which roughly multiplies the ~3 rps per-user budget (2 tokens -> ~5-6 rps).
S1_LRQ_TOKENS=
# Or a single token if you only have one service user:
S1_CONSOLE_API_TOKEN=

# ---- Optional engine tuning ----
# Per-token token-bucket rate. Stay under the 3 rps per-user cap.
S1_LRQ_RPS=2.5
# Comma-separated account IDs to scope the query (forces tenant=false). Leave blank
# for tenant=true. Set this if tenant=true returns matchCount=0 on a multi-account tenant.
S1_LRQ_ACCOUNT_IDS=
SDL_VERIFY_TLS=true

# ---- Output ----
# Default output folder. In Docker this is the mount point (-v host_dir:/data).
S1IE_OUTPUT_DIR=/data

# ---- UI server ----
S1IE_PORT=8801
S1IE_HOST=127.0.0.1
# Extra allowed browser origins (comma-separated) for hosted setups; local use needs none.
S1IE_ALLOWED_ORIGINS=

# ---- Network exposure (default is local/loopback only) ----
# Leave BIND_ALL unset for local use (in Docker, publish to the host loopback:
#   docker run -p 127.0.0.1:8901:8801 ...). To serve to other hosts, set S1IE_BIND_ALL=1
# AND a strong S1IE_AUTH_TOKEN; the server refuses to start exposed without a token, and
# every /api call must carry it (open the UI at http://<host>:8901/?token=<secret>).
S1IE_BIND_ALL=
S1IE_AUTH_TOKEN=
